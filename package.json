{
  "name": "webchat",
  "version": "1.0.0",
  "description": "Classic web-based chat application",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run src/__tests__/validate.test.js src/__tests__/validate.rooms.test.js src/__tests__/roomAuthorization.test.js src/__tests__/messageAuthorization.test.js src/__tests__/token.test.js src/__tests__/helpers/io.test.js src/__tests__/mailer.test.js src/__tests__/socket/index.test.js src/__tests__/socket/rooms.test.js",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^9.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "prisma": "^5.7.0",
    "sharp": "^0.33.1",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.17",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "src/**/*.{js,ts}": [
      "eslint --fix",
      "vitest run --reporter=verbose"
    ]
  }
}
